import React, { useState } from "react";

// ---------------------------------------------------------------------------
// AI Kitchen — the flagship feature.
//
// Flow:
//   1. The user types the ingredients they have (free text) and can
//      optionally pick a diet and a cuisine.
//   2. We POST that to a Cloudflare Worker, which calls the OpenAI API
//      (the API key lives safely on the Worker, never in the browser).
//   3. The Worker returns a recipe as JSON, which we render as a card.
//   4. The user can regenerate, or save the recipe to their browser
//      (localStorage) so it survives page refreshes.
//
// Backwards compatibility: if the older Worker (which returns plain text
// in `data.output`) is still deployed, we render that text gracefully too.
// ---------------------------------------------------------------------------

const WORKER_URL = "https://reggies-generate.hamza221hussain.workers.dev";

const dietOptions = ["Any", "Vegetarian", "Vegan", "Halal", "Pescatarian"];
const cuisineOptions = ["Surprise me", "Italian", "Pakistani", "Chinese", "Mexican", "French", "Thai"];

// Read saved recipes from localStorage (or an empty list on first visit)
function loadSaved() {
  try {
    return JSON.parse(localStorage.getItem("savedRecipes")) || [];
  } catch {
    return [];
  }
}

export default function AiKitchen() {
  const [ingredients, setIngredients] = useState("");
  const [diet, setDiet] = useState("Any");
  const [cuisine, setCuisine] = useState("Surprise me");

  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [recipe, setRecipe] = useState(null);     // structured recipe object
  const [rawText, setRawText] = useState("");     // fallback for old Worker
  const [saved, setSaved] = useState(loadSaved);

  const handleGenerate = async () => {
    if (!ingredients.trim()) {
      setError("Tell the kitchen what ingredients you have first.");
      return;
    }
    setError("");
    setRecipe(null);
    setRawText("");
    setLoading(true);

    try {
      const res = await fetch(WORKER_URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          ingredients: ingredients.trim(),
          diet: diet === "Any" ? "" : diet.toLowerCase(),
          cuisine: cuisine === "Surprise me" ? "" : cuisine.toLowerCase(),
          // `culture` kept for compatibility with the original Worker
          culture: cuisine === "Surprise me" ? "any" : cuisine.toLowerCase()
        })
      });

      const data = await res.json();

      if (res.ok && data.recipe) {
        // New Worker: structured JSON recipe
        setRecipe(data.recipe);
      } else if (res.ok && data.output) {
        // Old Worker: plain text — try to parse JSON out of it, else show text
        try {
          setRecipe(JSON.parse(data.output));
        } catch {
          setRawText(data.output);
        }
      } else {
        setError(data.error || `The kitchen returned an error (status ${res.status}). Try again in a moment.`);
      }
    } catch (e) {
      setError("Couldn't reach the AI kitchen. Check your connection and try again.");
    } finally {
      setLoading(false);
    }
  };

  const handleSave = () => {
    if (!recipe) return;
    const updated = [...saved, { ...recipe, savedAt: Date.now() }];
    setSaved(updated);
    localStorage.setItem("savedRecipes", JSON.stringify(updated));
  };

  const handleDelete = (savedAt) => {
    const updated = saved.filter((r) => r.savedAt !== savedAt);
    setSaved(updated);
    localStorage.setItem("savedRecipes", JSON.stringify(updated));
  };

  const alreadySaved = recipe && saved.some((r) => r.title === recipe.title);

  // Small helper for chip rows
  const chipRow = (options, selected, setSelected) => (
    <div className="flex flex-wrap gap-2">
      {options.map((option) => (
        <button
          key={option}
          onClick={() => setSelected(option)}
          className={`px-3.5 py-1.5 rounded-full text-sm font-semibold transition-colors
                      focus:outline-none focus:ring-2 focus:ring-basil ${
                        selected === option
                          ? "bg-pine text-paper"
                          : "bg-white border border-pine/15 text-ink/70 hover:bg-leaf"
                      }`}
        >
          {option}
        </button>
      ))}
    </div>
  );

  return (
    <div className="max-w-3xl mx-auto px-4 sm:px-6 py-12">
      <p className="font-mono text-xs uppercase tracking-widest text-saffron mb-3">
        Powered by OpenAI via Cloudflare Workers
      </p>
      <h1 className="font-display text-4xl text-pine">The AI Kitchen</h1>
      <p className="text-ink/70 mt-2">
        Tell the kitchen what you&rsquo;ve got, and it will invent a complete recipe
        just for you — ingredients, quantities and method included.
      </p>

      {/* ---------------- Input form ---------------- */}
      <div className="bg-white border border-pine/10 rounded-2xl shadow-sm p-6 mt-8 space-y-6">
        <div>
          <label htmlFor="ingredients" className="font-mono text-xs uppercase tracking-widest text-ink/50 block mb-2">
            What&rsquo;s in your fridge?
          </label>
          <textarea
            id="ingredients"
            value={ingredients}
            onChange={(e) => setIngredients(e.target.value)}
            rows={3}
            placeholder="e.g. chicken thighs, a tin of chickpeas, spinach, half a lemon…"
            className="w-full px-4 py-3 rounded-xl border border-pine/15 bg-paper
                       placeholder:text-ink/40 focus:outline-none focus:ring-2 focus:ring-basil resize-none"
          />
        </div>

        <div>
          <p className="font-mono text-xs uppercase tracking-widest text-ink/50 mb-2">Diet</p>
          {chipRow(dietOptions, diet, setDiet)}
        </div>

        <div>
          <p className="font-mono text-xs uppercase tracking-widest text-ink/50 mb-2">Cuisine</p>
          {chipRow(cuisineOptions, cuisine, setCuisine)}
        </div>

        <button
          onClick={handleGenerate}
          disabled={loading}
          className="w-full sm:w-auto px-8 py-3 bg-pine text-paper font-semibold rounded-full
                     hover:bg-basil transition-colors disabled:opacity-50
                     focus:outline-none focus:ring-2 focus:ring-basil"
        >
          {loading ? "Cooking up ideas…" : recipe || rawText ? "Generate another" : "Generate my recipe"}
        </button>

        {error && (
          <p className="text-red-700 bg-red-50 border border-red-200 rounded-xl px-4 py-3 text-sm">
            {error}
          </p>
        )}
      </div>

      {/* ---------------- Loading skeleton ---------------- */}
      {loading && (
        <div className="mt-8 bg-white border-2 border-dashed border-pine/20 rounded-2xl p-6 animate-pulse space-y-4">
          <div className="h-6 bg-leaf rounded w-2/3" />
          <div className="h-4 bg-leaf rounded w-full" />
          <div className="h-4 bg-leaf rounded w-5/6" />
          <div className="h-4 bg-leaf rounded w-4/6" />
        </div>
      )}

      {/* ---------------- Structured recipe card ---------------- */}
      {recipe && !loading && (
        <article className="mt-8 bg-white border-2 border-dashed border-pine/30 rounded-2xl p-6 sm:p-8">
          <p className="font-mono text-xs uppercase tracking-widest text-saffron mb-2">
            ✦ Freshly generated
          </p>
          <h2 className="font-display text-2xl text-pine">{recipe.title}</h2>
          {recipe.description && <p className="text-ink/70 mt-2">{recipe.description}</p>}

          <div className="flex flex-wrap gap-4 mt-4 font-mono text-xs text-ink/60">
            {recipe.time && <span>⏱ {recipe.time}</span>}
            {recipe.serves && <span>serves {recipe.serves}</span>}
          </div>

          {recipe.ingredients && (
            <>
              <h3 className="font-mono text-xs uppercase tracking-widest text-saffron mt-6 mb-2">
                Ingredients
              </h3>
              <ul className="space-y-1.5">
                {recipe.ingredients.map((item, idx) => (
                  <li key={idx} className="flex gap-2 text-ink/90">
                    <span className="text-basil">•</span> {item}
                  </li>
                ))}
              </ul>
            </>
          )}

          {recipe.steps && (
            <>
              <h3 className="font-mono text-xs uppercase tracking-widest text-saffron mt-6 mb-2">
                Method
              </h3>
              <ol className="space-y-3">
                {recipe.steps.map((step, idx) => (
                  <li key={idx} className="flex gap-3">
                    <span className="font-mono text-sm text-basil shrink-0">{idx + 1}.</span>
                    <span className="text-ink/90">{step}</span>
                  </li>
                ))}
              </ol>
            </>
          )}

          <button
            onClick={handleSave}
            disabled={alreadySaved}
            className="mt-8 px-6 py-2.5 bg-saffron/90 text-pine font-semibold rounded-full
                       hover:bg-saffron transition-colors disabled:opacity-50
                       focus:outline-none focus:ring-2 focus:ring-basil"
          >
            {alreadySaved ? "Saved ✓" : "Save this recipe"}
          </button>
        </article>
      )}

      {/* ---------------- Plain-text fallback (old Worker) ---------------- */}
      {rawText && !loading && (
        <article className="mt-8 bg-white border-2 border-dashed border-pine/30 rounded-2xl p-6 sm:p-8">
          <p className="font-mono text-xs uppercase tracking-widest text-saffron mb-3">
            ✦ Freshly generated
          </p>
          <div className="whitespace-pre-wrap text-ink/90">{rawText}</div>
        </article>
      )}

      {/* ---------------- Saved recipes ---------------- */}
      {saved.length > 0 && (
        <section className="mt-14">
          <h2 className="font-display text-2xl text-pine mb-1">Your saved recipes</h2>
          <p className="text-ink/60 text-sm mb-6">
            Stored in this browser only — no account needed.
          </p>
          <div className="space-y-4">
            {saved.map((item) => (
              <details
                key={item.savedAt}
                className="bg-white border border-pine/10 rounded-2xl p-5 open:shadow-md"
              >
                <summary className="cursor-pointer font-display text-lg text-pine list-none flex items-center justify-between gap-4">
                  <span>{item.title}</span>
                  <span className="font-mono text-xs text-ink/40">tap to open</span>
                </summary>
                {item.description && <p className="text-ink/70 mt-3">{item.description}</p>}
                {item.ingredients && (
                  <ul className="mt-3 space-y-1 text-sm text-ink/80">
                    {item.ingredients.map((ing, idx) => (
                      <li key={idx}>• {ing}</li>
                    ))}
                  </ul>
                )}
                {item.steps && (
                  <ol className="mt-3 space-y-2 text-sm text-ink/80 list-decimal list-inside">
                    {item.steps.map((step, idx) => (
                      <li key={idx}>{step}</li>
                    ))}
                  </ol>
                )}
                <button
                  onClick={() => handleDelete(item.savedAt)}
                  className="mt-4 text-sm text-red-700 underline underline-offset-4 hover:text-red-800"
                >
                  Remove
                </button>
              </details>
            ))}
          </div>
        </section>
      )}
    </div>
  );
}
