import React from "react";

// One recipe card. Clicking it calls onOpen(recipe) so the parent
// page can show the full recipe in a modal.
export default function RecipeCard({ recipe, onOpen }) {
  return (
    <button
      onClick={() => onOpen(recipe)}
      className="text-left bg-white rounded-2xl overflow-hidden border border-pine/10 shadow-sm
                 hover:shadow-lg hover:-translate-y-1 transition-all duration-200
                 focus:outline-none focus:ring-2 focus:ring-basil"
    >
      <div className="relative">
        <img
          src={recipe.img}
          alt={recipe.name}
          className="w-full h-48 object-cover"
          loading="lazy"
        />
        {/* Diet badge */}
        <span className="absolute top-3 left-3 bg-paper/95 text-pine font-mono text-xs px-2.5 py-1 rounded-full">
          {recipe.diet}
        </span>
      </div>
      <div className="p-5">
        <h3 className="font-display text-lg text-pine leading-snug">{recipe.name}</h3>
        <p className="text-sm text-ink/70 mt-2 line-clamp-2">{recipe.description}</p>
        <div className="flex items-center gap-4 mt-4 font-mono text-xs text-ink/60">
          <span>⏱ {recipe.time}</span>
          <span>serves {recipe.serves}</span>
        </div>
      </div>
    </button>
  );
}
